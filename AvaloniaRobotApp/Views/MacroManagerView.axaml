<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaRobotApp.ViewModels"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="AvaloniaRobotApp.Views.MacroManagerView"
             x:DataType="vm:MacroManagerViewModel">
    
    <Panel Background="#1e1e2e">
        <ScrollViewer>
            <StackPanel Margin="40" Spacing="25">
                <TextBlock Text="Macro Manager" FontSize="28" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Automate system tasks and utility operations." Foreground="#a6adc8"/>

                <!-- Network Macro -->
                <Border Background="#313244" CornerRadius="12" Padding="25">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ic:SymbolIcon Symbol="NetworkCheck" Foreground="#89b4fa" FontSize="20"/>
                            <TextBlock Text="System Optimization" FontSize="18" FontWeight="SemiBold" Foreground="#89b4fa" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Flush DNS and renew DHCP lease to resolve connectivity issues." FontSize="14" Foreground="#bac2de" TextWrapping="Wrap"/>
                        <Button Command="{Binding ResetNetworkCommand}" 
                                Classes="Primary"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:SymbolIcon Symbol="Flash"/>
                                <TextBlock Text="Reset Network Stack"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Password Macro -->
                <Border Background="#313244" CornerRadius="12" Padding="25">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ic:SymbolIcon Symbol="LockShield" Foreground="#a6e3a1" FontSize="20"/>
                            <TextBlock Text="Security Utilities" FontSize="18" FontWeight="SemiBold" Foreground="#a6e3a1" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Generate a secure, random password." FontSize="14" Foreground="#bac2de"/>
                        
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                            <TextBox Text="{Binding GeneratedPassword}" 
                                     IsReadOnly="True" 
                                     Watermark="Password will appear here..."/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Command="{Binding GeneratePasswordCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:SymbolIcon Symbol="Key"/>
                                        <TextBlock Text="Generate"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CopyPasswordCommand}" IsEnabled="{Binding GeneratedPassword.Length}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:SymbolIcon Symbol="Copy"/>
                                        <TextBlock Text="Copy"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Status Bar -->
                <Border Background="#45475a" CornerRadius="8" Padding="15,10">
                    <TextBlock Text="{Binding MacroStatus}" Foreground="#cdd6f4" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Panel>
</UserControl>
