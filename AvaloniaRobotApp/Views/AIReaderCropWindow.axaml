<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AvaloniaRobotApp.Views.AIReaderCropWindow"
        Title="AI Reader Crop"
        SystemDecorations="None"
        Topmost="True"
        WindowState="FullScreen"
        Background="Black"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome">
    
    <Panel Name="MainPanel">
        <Image Name="BackgroundImage" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Canvas Name="DrawingCanvas" Background="Transparent" />
        
        <!-- Instruction text - centered to indicate preview mode -->
        <Border Name="InstructionBorder"
                Background="#DD000000" 
                CornerRadius="12" 
                Padding="35,20" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                IsHitTestVisible="False">
            <TextBlock Text="Select area for AI analysis (Esc to cancel)" 
                       Foreground="Cyan" 
                       FontSize="26" 
                       FontWeight="SemiBold"/>
        </Border>
    </Panel>
</Window>
