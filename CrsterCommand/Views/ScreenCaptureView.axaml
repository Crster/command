<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrsterCommand.ViewModels"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="CrsterCommand.Views.ScreenCaptureView"
             x:DataType="vm:ScreenCaptureViewModel">
    
    <Panel Background="#1e1e2e">
        <StackPanel Margin="40" Spacing="20">
            <TextBlock Text="Screen Capture &amp; Annotation" FontSize="28" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Capture any part of your screen and add annotations." Foreground="#a6adc8"/>
            
            <Border Background="#313244" CornerRadius="12" Padding="30">
                <StackPanel Spacing="20" HorizontalAlignment="Center">
                    <Button Command="{Binding StartCaptureCommand}" 
                            Classes="Primary"
                            Width="250"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ic:SymbolIcon Symbol="CameraAdd"/>
                            <TextBlock Text="New Screen Capture"/>
                        </StackPanel>
                    </Button>
                    
                    <TextBlock Text="Recent Captures will appear here" FontStyle="Italic" Foreground="#6c7086" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Image Source="{Binding CapturedImage}" MaxHeight="300" Stretch="Uniform"/>
        </StackPanel>
    </Panel>
</UserControl>
