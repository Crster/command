<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrsterCommand.ViewModels"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="CrsterCommand.Views.ScreenCaptureView"
             x:DataType="vm:ScreenCaptureViewModel">

    <ScrollViewer Background="Transparent">
        <StackPanel Margin="32" Spacing="20">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Classes="PageTitle"    Text="Screen Capture"/>
                <TextBlock Classes="PageSubtitle" Text="Capture any part of your screen and add annotations"/>
            </StackPanel>

            <!-- Capture Card -->
            <Border Classes="Card">
                <StackPanel Spacing="20" HorizontalAlignment="Center">

                    <Button Command="{Binding StartCaptureCommand}"
                            Classes="Primary"
                            Width="260"
                            Height="44"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ic:SymbolIcon Symbol="CameraAdd" FontSize="18"/>
                            <TextBlock Text="New Screen Capture" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="Recent captures will appear here"
                               FontStyle="Italic"
                               FontSize="13"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               HorizontalAlignment="Center"/>

                </StackPanel>
            </Border>

            <Image Source="{Binding CapturedImage}" MaxHeight="300" Stretch="Uniform"/>

        </StackPanel>
    </ScrollViewer>

</UserControl>
