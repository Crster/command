<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrsterCommand.ViewModels"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="CrsterCommand.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer Background="Transparent">
        <StackPanel Margin="32" Spacing="20">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Classes="PageTitle"    Text="Settings"/>
                <TextBlock Classes="PageSubtitle" Text="Configure your toolkit preferences"/>
            </StackPanel>

            <!-- Database Card -->
            <Border Classes="Card">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:SymbolIcon Symbol="Database"
                                       Foreground="{DynamicResource AppAccentBrush}"
                                       FontSize="20"/>
                        <TextBlock Classes="SectionHeader"
                                   Text="Database Configuration"
                                   Foreground="{DynamicResource AppAccentBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Set the location of your LiteDB file. Default is your Documents folder."
                               FontSize="13"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <TextBox Text="{Binding DbPath}" IsReadOnly="True" Watermark="Path to toolkit.db..."/>
                        <Button Grid.Column="1" Command="{Binding BrowsePathCommand}" Classes="Primary">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:SymbolIcon Symbol="FolderOpen"/>
                                <TextBlock Text="Browse"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Gemini AI Card -->
            <Border Classes="Card">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:SymbolIcon Symbol="Bot"
                                       Foreground="{DynamicResource AppWarningBrush}"
                                       FontSize="20"/>
                        <TextBlock Classes="SectionHeader"
                                   Text="Gemini AI Configuration"
                                   Foreground="{DynamicResource AppWarningBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Configure your native Gemini AI settings for intelligent features."
                               FontSize="13"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="Label" Text="API Key"/>
                        <TextBox Text="{Binding AiApiKey}"
                                 PasswordChar="*"
                                 Watermark="Enter your Gemini API Key..."/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="Label" Text="Select Model"/>
                        <ComboBox ItemsSource="{Binding AiModelOptions}"
                                  SelectedItem="{Binding AiModel}"
                                  IsEnabled="{Binding HasApiKey}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Vault Security Card -->
            <Border Classes="Card">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:SymbolIcon Symbol="ShieldLock"
                                       Foreground="{DynamicResource AppAccentBrush}"
                                       FontSize="20"/>
                        <TextBlock Classes="SectionHeader"
                                   Text="Vault Security"
                                   Foreground="{DynamicResource AppAccentBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Set a master password for your encrypted notes. This password is required to create or view Vault items."
                               FontSize="13"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="Label" Text="Master Password"/>
                        <TextBox Text="{Binding VaultPassword}"
                                 PasswordChar="*"
                                 Watermark="Enter vault master password..."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- FFmpeg Card -->
            <Border Classes="Card">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:SymbolIcon Symbol="Video"
                                       Foreground="{DynamicResource AppSuccessBrush}"
                                       FontSize="20"/>
                        <TextBlock Classes="SectionHeader"
                                   Text="FFmpeg (Screen Recorder)"
                                   Foreground="{DynamicResource AppSuccessBrush}"/>
                    </StackPanel>
                    <TextBlock Text="FFmpeg is required for the Screen Recorder feature to capture and encode video."
                               FontSize="13"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <!-- Installed state -->
                    <Border CornerRadius="8" Padding="14" IsVisible="{Binding IsFfmpegInstalled}"
                            Background="#1a2e1a" BorderBrush="#2a4a2a" BorderThickness="1">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <ic:SymbolIcon Grid.Column="0" Symbol="CheckmarkCircle"
                                           Foreground="{DynamicResource AppSuccessBrush}"
                                           FontSize="22" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="FFmpeg is installed" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppSuccessBrush}"/>
                                <TextBlock Text="{Binding FfmpegVersion}" FontSize="12"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Command="{Binding CheckFfmpegCommand}"
                                    IsEnabled="{Binding !IsCheckingFfmpeg}"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <ic:SymbolIcon Symbol="ArrowSync" FontSize="14"/>
                                    <TextBlock Text="Re-check"   IsVisible="{Binding !IsCheckingFfmpeg}"/>
                                    <TextBlock Text="Checking…" IsVisible="{Binding IsCheckingFfmpeg}"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Not installed state -->
                    <Border CornerRadius="8" Padding="14" IsVisible="{Binding !IsFfmpegInstalled}"
                            Background="#2e1a1a" BorderBrush="#4a2a2a" BorderThickness="1">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <ic:SymbolIcon Grid.Column="0" Symbol="DismissCircle"
                                           Foreground="{DynamicResource AppDangerBrush}"
                                           FontSize="22" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="FFmpeg not found" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppDangerBrush}"/>
                                <TextBlock Text="Install FFmpeg and add it to your system PATH."
                                           FontSize="12"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Command="{Binding CheckFfmpegCommand}"
                                    IsEnabled="{Binding !IsCheckingFfmpeg}"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <ic:SymbolIcon Symbol="ArrowSync" FontSize="14"/>
                                    <TextBlock Text="Re-check"   IsVisible="{Binding !IsCheckingFfmpeg}"/>
                                    <TextBlock Text="Checking…" IsVisible="{Binding IsCheckingFfmpeg}"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Button Command="{Binding OpenFfmpegDownloadCommand}"
                            IsVisible="{Binding !IsFfmpegInstalled}"
                            Classes="Primary">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="Open"/>
                            <TextBlock Text="Download FFmpeg"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <TextBlock Text="Settings are saved automatically upon change."
                       FontSize="12"
                       FontStyle="Italic"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"/>

        </StackPanel>
    </ScrollViewer>

</UserControl>
