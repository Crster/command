<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrsterCommand.ViewModels"
             xmlns:conv="using:CrsterCommand.Converters"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="CrsterCommand.Views.ScreenRecorderView"
             x:DataType="vm:ScreenRecorderViewModel">

    <UserControl.Resources>
        <conv:RecordingBrushConverter x:Key="RecordingBrushConverter"/>
        <conv:RecordingTextConverter  x:Key="RecordingTextConverter"/>
        <conv:FfmpegStatusBrushConverter x:Key="FfmpegStatusBrushConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.Recording">
            <Setter Property="Background" Value="#e85555"/>
            <Setter Property="BorderBrush"  Value="#e85555"/>
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.5">
                        <Setter Property="Opacity" Value="0.55"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:1">
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <ScrollViewer Background="Transparent">
        <StackPanel Margin="32" Spacing="20">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Classes="PageTitle"    Text="Screen Recorder"/>
                <TextBlock Classes="PageSubtitle" Text="Capture your screen into MP4 format"/>
            </StackPanel>

            <!-- Recorder Card -->
            <Border Classes="Card">
                <Grid HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Toggle button -->
                    <Button Grid.Row="0"
                            Command="{Binding ToggleRecordingCommand}"
                            IsEnabled="{Binding IsFfmpegAvailable}"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Width="260"
                            Height="48"
                            HorizontalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Classes="Primary"
                            Classes.Recording="{Binding IsRecording}">
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                            <ic:SymbolIcon Symbol="Record" IsVisible="{Binding !IsRecording}" FontSize="20"/>
                            <ic:SymbolIcon Symbol="Stop"   IsVisible="{Binding IsRecording}"  FontSize="20"/>
                            <TextBlock Text="{Binding IsRecording, Converter={StaticResource RecordingTextConverter}}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Status / saved link (share the same row) -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding StatusMessage}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               FontSize="13"
                               Foreground="{Binding IsFfmpegAvailable, Converter={StaticResource FfmpegStatusBrushConverter}}"
                               IsVisible="{Binding !HasSavedFile}"
                               Margin="0,24,0,0"/>

                    <Button Grid.Row="1"
                            Command="{Binding OpenSavedFolderCommand}"
                            IsVisible="{Binding HasSavedFile}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalAlignment="Center"
                            Margin="0,24,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <ic:SymbolIcon Symbol="FolderOpen"
                                           Foreground="{DynamicResource AppAccentBrush}"
                                           FontSize="14"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{DynamicResource AppAccentBrush}"
                                       TextDecorations="Underline"/>
                        </StackPanel>
                    </Button>

                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
