<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrsterCommand.ViewModels"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="700"
             x:Class="CrsterCommand.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <Design.DataContext>
        <vm:DashboardViewModel/>
    </Design.DataContext>

    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="Black"
                    TintOpacity="1"
                    MaterialOpacity="0.65" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="30" Spacing="25">
                <!-- Header -->
                <StackPanel Spacing="5">
                    <TextBlock Text="Robot Commander" 
                               FontSize="32" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="Automate your desktop with precision" 
                               FontSize="14" 
                               Foreground="#a6adc8"/>
                </StackPanel>

                <!-- Mouse Control Card -->
                <Border Background="#313244" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ic:SymbolIcon Symbol="Cursor" Foreground="#89b4fa" FontSize="20"/>
                            <TextBlock Text="Mouse Control" FontSize="18" FontWeight="SemiBold" Foreground="#89b4fa" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="10" RowSpacing="10">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="5">
                                <TextBlock Text="X Coordinate" FontSize="12" Foreground="#bac2de"/>
                                <NumericUpDown Value="{Binding MouseX}" Minimum="0" Maximum="3840"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="5">
                                <TextBlock Text="Y Coordinate" FontSize="12" Foreground="#bac2de"/>
                                <NumericUpDown Value="{Binding MouseY}" Minimum="0" Maximum="2160"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Command="{Binding MoveMouseCommand}" 
                                    Classes="Primary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:SymbolIcon Symbol="CursorClick"/>
                                    <TextBlock Text="Move Mouse"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ClickLeftCommand}" 
                                    Classes="Secondary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:SymbolIcon Symbol="Cursor"/>
                                    <TextBlock Text="Left Click"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Keyboard Control Card -->
                <Border Background="#313244" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ic:SymbolIcon Symbol="Keyboard" Foreground="#a6e3a1" FontSize="20"/>
                            <TextBlock Text="Keyboard Automation" FontSize="18" FontWeight="SemiBold" Foreground="#a6e3a1" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="5">
                            <TextBlock Text="Text to Type" FontSize="12" Foreground="#bac2de"/>
                            <TextBox Text="{Binding TextToType}" Watermark="Type something..."/>
                        </StackPanel>

                        <Button Command="{Binding TypeTextCommand}" 
                                Classes="Success"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:SymbolIcon Symbol="Keyboard"/>
                                <TextBlock Text="Type in 2 Seconds"/>
                            </StackPanel>
                        </Button>
                        
                        <TextBlock Text="Tip: Click the button, then focus on another text field." 
                                   FontSize="11" 
                                   FontStyle="Italic"
                                   Foreground="#9399b2"/>
                    </StackPanel>
                </Border>

                <!-- Status Bar -->
                <Border Background="#45475a" CornerRadius="8" Padding="15,10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Ellipse Width="10" Height="10" Fill="#f9e2af"/>
                        <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="#cdd6f4"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Panel>

    <UserControl.Styles>
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#11111b"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="#cba6f7"/>
            <Setter Property="Foreground" Value="#11111b"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.Success">
            <Setter Property="Background" Value="#a6e3a1"/>
            <Setter Property="Foreground" Value="#11111b"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>
</UserControl>
