<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrsterCommand.ViewModels"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="700"
             x:Class="CrsterCommand.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <Design.DataContext>
        <vm:DashboardViewModel/>
    </Design.DataContext>

    <ScrollViewer Background="Transparent"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32" Spacing="20">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Classes="PageTitle"   Text="Robot Commander"/>
                <TextBlock Classes="PageSubtitle" Text="Automate your desktop with precision"/>
            </StackPanel>

            <!-- Mouse Control Card -->
            <Border Classes="Card">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:SymbolIcon Symbol="Cursor"
                                       Foreground="{DynamicResource AppAccentBrush}"
                                       FontSize="20"/>
                        <TextBlock Classes="SectionHeader"
                                   Text="Mouse Control"
                                   Foreground="{DynamicResource AppAccentBrush}"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="Label" Text="X Coordinate"/>
                            <NumericUpDown Value="{Binding MouseX}" Minimum="0" Maximum="3840"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Classes="Label" Text="Y Coordinate"/>
                            <NumericUpDown Value="{Binding MouseY}" Minimum="0" Maximum="2160"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Command="{Binding MoveMouseCommand}" Classes="Primary">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:SymbolIcon Symbol="CursorClick"/>
                                <TextBlock Text="Move Mouse"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ClickLeftCommand}" Classes="Secondary">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:SymbolIcon Symbol="Cursor"/>
                                <TextBlock Text="Left Click"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Keyboard Control Card -->
            <Border Classes="Card">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:SymbolIcon Symbol="Keyboard"
                                       Foreground="{DynamicResource AppSuccessBrush}"
                                       FontSize="20"/>
                        <TextBlock Classes="SectionHeader"
                                   Text="Keyboard Automation"
                                   Foreground="{DynamicResource AppSuccessBrush}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="Label" Text="Text to Type"/>
                        <TextBox Text="{Binding TextToType}" Watermark="Type something..."/>
                    </StackPanel>

                    <Button Command="{Binding TypeTextCommand}"
                            Classes="Success"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="Keyboard"/>
                            <TextBlock Text="Type in 2 Seconds"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="Tip: Click the button, then focus on another text field."
                               FontSize="11"
                               FontStyle="Italic"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                </StackPanel>
            </Border>

            <!-- Status Bar -->
            <Border Classes="StatusBar">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Ellipse Width="8" Height="8"
                             Fill="{DynamicResource AppAccentBrush}"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
