<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrsterCommand.ViewModels"
             xmlns:models="using:CrsterCommand.Models"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:conv="using:CrsterCommand.Converters"
             xmlns:views="using:CrsterCommand.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="CrsterCommand.Views.NotesView"
             x:DataType="vm:NotesViewModel">

    <UserControl.Resources>
        <conv:EqualsConverter x:Key="EqualsConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">
        
        <!-- Header Section -->
        <Border Grid.Row="0" Padding="32,32,32,16">
            <StackPanel Spacing="20">
                <StackPanel Spacing="4">
                    <TextBlock Classes="PageTitle" Text="Notes &amp; Memories"/>
                    <TextBlock Classes="PageSubtitle" Text="Seamlessly capture and find everything with semantic search."/>
                </StackPanel>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                             Watermark="Semantic search... try searching by meaning"
                             Classes="RevealPasswordButton">
                        <TextBox.InnerLeftContent>
                            <ic:SymbolIcon Symbol="Search" Margin="12,0,0,0" FontSize="18" Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                        </TextBox.InnerLeftContent>
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding SemanticSearchCommand}"/>
                        </TextBox.KeyBindings>
                    </TextBox>
                    
                    <Button Grid.Column="1" 
                            Command="{Binding $parent[views:NotesView].OpenAddDialogCommand}"
                            Classes="Primary"
                            Width="40" Height="40" Padding="0">
                        <ic:SymbolIcon Symbol="Add" FontSize="20"/>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Main Listing -->
        <ScrollViewer Grid.Row="1" 
                      Name="MainScrollViewer"
                      ScrollChanged="MainScrollViewer_ScrollChanged"
                      HorizontalScrollBarVisibility="Disabled">
            <ListBox ItemsSource="{Binding AllNotes}" 
                     Background="Transparent" 
                     BorderThickness="0"
                     Margin="32,0,32,32"
                     SelectedItem="{Binding SelectedNote}"
                     DoubleTapped="NotesList_DoubleTapped"
                     HorizontalAlignment="Stretch">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,3"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover Border.Card">
                        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource AppStatusBarBrush}"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListBox.Styles>
                
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:BaseNoteItem">
                        <Border Classes="Card" Padding="16">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                
                                <!-- Icon / Type Indicator -->
                                <Border Grid.Column="0" 
                                        Width="48" Height="48" 
                                        CornerRadius="12"
                                        Background="{DynamicResource AppInputBackgroundBrush}"
                                        VerticalAlignment="Top">
                                    <Panel>
                                        <!-- Todo Icon -->
                                        <ic:SymbolIcon Symbol="List" FontSize="22" 
                                                       IsVisible="{Binding Type, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static models:NoteType.Todo}}"
                                                       Foreground="{DynamicResource AppAccentBrush}"/>
                                        <!-- Memory Icon -->
                                        <ic:SymbolIcon Symbol="BrainCircuit" FontSize="22" 
                                                       IsVisible="{Binding Type, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static models:NoteType.Memory}}"
                                                       Foreground="{DynamicResource AppSuccessBrush}"/>
                                        <!-- Vault Icon -->
                                        <ic:SymbolIcon Symbol="LockClosed" FontSize="22" 
                                                       IsVisible="{Binding Type, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static models:NoteType.Vault}}"
                                                       Foreground="{DynamicResource AppWarningBrush}"/>
                                        <!-- File Icon -->
                                        <ic:SymbolIcon Symbol="Document" FontSize="22" 
                                                       IsVisible="{Binding Type, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static models:NoteType.File}}"
                                                       Foreground="{DynamicResource AppSecondaryAccentBrush}"/>
                                    </Panel>
                                </Border>

                                <!-- Content Summary -->
                                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                    <TextBlock Text="{Binding Summary}" 
                                               FontSize="16" 
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppPrimaryTextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"
                                               HorizontalAlignment="Stretch"/>
                                    
                                    <TextBlock Text="{Binding DisplayDescription}" 
                                               FontSize="13" 
                                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               LineHeight="18"
                                               HorizontalAlignment="Stretch"
                                               IsVisible="{Binding DisplayDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding DetailInfo}" 
                                                   FontSize="12" 
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                                        <TextBlock Text="•" Foreground="{DynamicResource AppSubtleTextBrush}"/>
                                        <TextBlock Text="{Binding LastModified, StringFormat='{}{0:MMM dd, yyyy HH:mm}'}" 
                                                   FontSize="12"
                                                   Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Actions -->
                                <Button Grid.Column="2" 
                                        Classes="Danger" 
                                        Width="32" Height="32" Padding="0"
                                        Command="{Binding $parent[UserControl].((vm:NotesViewModel)DataContext).DeleteItemCommand}"
                                        CommandParameter="{Binding}"
                                        VerticalAlignment="Center">
                                    <ic:SymbolIcon Symbol="Delete" FontSize="16"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </Grid>
</UserControl>
