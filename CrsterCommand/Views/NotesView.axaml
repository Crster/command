<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrsterCommand.ViewModels"
             xmlns:models="using:CrsterCommand.Models"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="CrsterCommand.Views.NotesView"
             x:DataType="vm:NotesViewModel">

    <TabControl Background="Transparent" Padding="24">

        <!-- ── Todo Tab ── -->
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ic:SymbolIcon Symbol="List"/>
                    <TextBlock Text="Todo List"/>
                </StackPanel>
            </TabItem.Header>
            <StackPanel Spacing="14" Margin="0,16,0,0">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBox Text="{Binding NewTodoTask}" Watermark="New task…"/>
                    <Button Grid.Column="1" Command="{Binding AddTodoCommand}" Classes="Primary">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="Add"/>
                            <TextBlock Text="Add Task"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <ListBox ItemsSource="{Binding Todos}" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:TodoItem">
                            <Border Classes="Card" Padding="12" Margin="0,3">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <CheckBox IsChecked="{Binding IsDone}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Task}"
                                               VerticalAlignment="Center"
                                               Margin="10,0"
                                               FontSize="13"/>
                                    <Button Grid.Column="2"
                                            Classes="Danger"
                                            Padding="10,0"
                                            MinHeight="32"
                                            Command="{Binding $parent[UserControl].((vm:NotesViewModel)DataContext).DeleteTodoCommand}"
                                            CommandParameter="{Binding}">
                                        <ic:SymbolIcon Symbol="Delete" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </TabItem>

        <!-- ── Memory Bank Tab ── -->
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ic:SymbolIcon Symbol="BrainCircuit"/>
                    <TextBlock Text="Memory Bank"/>
                </StackPanel>
            </TabItem.Header>
            <Grid ColumnDefinitions="230,*" ColumnSpacing="20" Margin="0,16,0,0">

                <!-- Left panel -->
                <StackPanel Spacing="10">
                    <TextBox Text="{Binding SearchQuery}" Watermark="Semantic search…"/>
                    <Button Command="{Binding SemanticSearchCommand}"
                            HorizontalAlignment="Stretch"
                            Classes="Secondary">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="Wand"/>
                            <TextBlock Text="Search by Meaning"/>
                        </StackPanel>
                    </Button>

                    <Border Height="1"
                            Background="{DynamicResource AppInputBorderBrush}"
                            Margin="0,4"/>

                    <Button Command="{Binding AddNoteCommand}" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="NoteAdd"/>
                            <TextBlock Text="New Note"/>
                        </StackPanel>
                    </Button>

                    <ListBox ItemsSource="{Binding MemoryNotes}"
                             SelectedItem="{Binding SelectedNote}"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:MemoryNote">
                                <TextBlock Text="{Binding Title}" FontSize="13" Margin="4,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <!-- Editor panel -->
                <Border Grid.Column="1" Classes="Card">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Text="{Binding SelectedNote.Title, FallbackValue=''}"
                                     Watermark="Title"
                                     FontSize="16"
                                     FontWeight="SemiBold"/>
                            <Button Grid.Column="1"
                                    Command="{Binding SaveNoteCommand}"
                                    Classes="Success"
                                    Margin="10,0,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:SymbolIcon Symbol="Save"/>
                                    <TextBlock Text="Save"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBox Text="{Binding SelectedNote.Content, FallbackValue=''}"
                                 Watermark="Content…"
                                 AcceptsReturn="True"
                                 MinHeight="360"/>
                    </StackPanel>
                </Border>

            </Grid>
        </TabItem>

        <!-- ── File Vault Tab ── -->
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ic:SymbolIcon Symbol="FolderZip"/>
                    <TextBlock Text="File Vault"/>
                </StackPanel>
            </TabItem.Header>
            <StackPanel Spacing="14" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Command="{Binding UploadFileCommand}" Classes="Primary">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="DocumentAdd"/>
                            <TextBlock Text="Upload File"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding AttachClipboardCommand}" Classes="Secondary">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="ClipboardPaste"/>
                            <TextBlock Text="Attach Clipboard"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <ListBox ItemsSource="{Binding AttachedFiles}" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Classes="Card" Padding="12" Margin="0,3">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{Binding}"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                                    <Button Grid.Column="1" Content="Remove"
                                            Classes="Danger"
                                            Padding="12,0"
                                            MinHeight="32"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </TabItem>

        <!-- ── Secure Vault Tab ── -->
        <TabItem Header="Secure Vault">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="18"
                        Margin="0,40">
                <ic:SymbolIcon Symbol="LockClosed"
                               FontSize="52"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                <TextBlock Text="The vault is currently locked."
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                <TextBox Watermark="Enter Master Password…" PasswordChar="*" Width="260"/>
                <Button Content="Unlock Vault" Classes="Primary" HorizontalAlignment="Center"/>
            </StackPanel>
        </TabItem>

    </TabControl>

</UserControl>
