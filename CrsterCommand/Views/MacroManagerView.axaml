<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrsterCommand.ViewModels"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="CrsterCommand.Views.MacroManagerView"
             x:DataType="vm:MacroManagerViewModel">

    <ScrollViewer Background="Transparent">
        <StackPanel Margin="32" Spacing="20">

            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Classes="PageTitle"    Text="Macro Manager"/>
                <TextBlock Classes="PageSubtitle" Text="Automate system tasks and utility operations"/>
            </StackPanel>

            <!-- Network Card -->
            <Border Classes="Card">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:SymbolIcon Symbol="NetworkCheck"
                                       Foreground="{DynamicResource AppAccentBrush}"
                                       FontSize="20"/>
                        <TextBlock Classes="SectionHeader"
                                   Text="System Optimization"
                                   Foreground="{DynamicResource AppAccentBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Flush DNS and renew DHCP lease to resolve connectivity issues."
                               FontSize="13"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                    <Button Command="{Binding ResetNetworkCommand}"
                            Classes="Primary"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="Flash"/>
                            <TextBlock Text="Reset Network Stack"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Password Card -->
            <Border Classes="Card">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:SymbolIcon Symbol="LockShield"
                                       Foreground="{DynamicResource AppSuccessBrush}"
                                       FontSize="20"/>
                        <TextBlock Classes="SectionHeader"
                                   Text="Security Utilities"
                                   Foreground="{DynamicResource AppSuccessBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Generate a secure, random password."
                               FontSize="13"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"/>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <TextBox Text="{Binding GeneratedPassword}"
                                 IsReadOnly="True"
                                 Watermark="Password will appear here…"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding GeneratePasswordCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:SymbolIcon Symbol="Key"/>
                                    <TextBlock Text="Generate"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding CopyPasswordCommand}"
                                    IsEnabled="{Binding GeneratedPassword.Length}"
                                    Classes="Secondary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:SymbolIcon Symbol="Copy"/>
                                    <TextBlock Text="Copy"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Status Bar -->
            <Border Classes="StatusBar">
                <TextBlock Text="{Binding MacroStatus}"
                           FontSize="13"
                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                           TextWrapping="Wrap"/>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
