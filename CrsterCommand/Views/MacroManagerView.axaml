<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrsterCommand.ViewModels"
             xmlns:models="using:CrsterCommand.Models"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:views="using:CrsterCommand.Views"
             xmlns:conv="using:CrsterCommand.Converters"
             x:Class="CrsterCommand.Views.MacroManagerView"
             x:DataType="vm:MacroManagerViewModel">

    <UserControl.Styles>
        <Style Selector="Button.CardHeaderButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.CardHeaderButton:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.CardHeaderButton:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.CardHeaderButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.CardHeaderButton:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="Border.AiAppCard:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
        </Style>
        <Style Selector="Border.AiAppCard.expanded">
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
        </Style>

        <Style Selector="Border.ChatComposer:focus-within">
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
        </Style>

        <Style Selector="TextBox.ComposerInput">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="TextBox.ComposerInput:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.ComposerInput:focus">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.ComposerInput /template/ Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="Button.SendIconButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.SendIconButton:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.SendIconButton:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.SendIconButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.SendIconButton:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.SendIconButton:disabled">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.SendIconButton:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.AttachIndicator">
            <Setter Property="Background" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="MaxWidth" Value="28"/>
            <Setter Property="MaxHeight" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.AttachIndicator:pointerover">
            <Setter Property="Opacity" Value="0.95"/>
        </Style>

        <Style Selector="Button.DeleteIconButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppDangerBrush}"/>
        </Style>
        <Style Selector="Button.DeleteIconButton:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppDangerBrush}"/>
        </Style>
        <Style Selector="Button.DeleteIconButton:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppDangerBrush}"/>
        </Style>
        <Style Selector="Button.DeleteIconButton:disabled">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppDangerBrush}"/>
        </Style>
        <Style Selector="Button.DeleteIconButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.DeleteIconButton:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.DeleteIconButton:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="TextBox.AiAnswerBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="TextBox.AiAnswerBox:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.AiAnswerBox:focus">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.AiAnswerBox /template/ Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <conv:NullToBoolConverter x:Key="NullToBool" />
        <conv:FileAttachmentToTooltipConverter x:Key="AttachmentTooltip" />
    </UserControl.Resources>

    <ScrollViewer Background="Transparent">
        <StackPanel Margin="32" Spacing="20">

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Classes="PageTitle" Text="Macro Manager"/>
                    <TextBlock Classes="PageSubtitle" Text="Create AI apps with system prompts and run quick tasks"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Command="{Binding $parent[views:MacroManagerView].OpenAddDialogCommand}"
                        Classes="Primary"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ic:SymbolIcon Symbol="Add"/>
                        <TextBlock Text="Add Macro"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Mouse the move -->
            <Border Classes="Card AiAppCard" Padding="14">
                <Button Classes="CardHeaderButton"
                        BorderThickness="0"
                        Padding="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Command="{Binding ToggleRobotCommand}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Desktop Robot" FontWeight="SemiBold"/>
                            <TextBlock Text="Automate your life and take a rest!" FontSize="12" Foreground="{DynamicResource ApplicationForegroundSecondaryBrush}"/>
                        </StackPanel>
                        <ic:SymbolIcon Grid.Column="1" Symbol="Play" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </Border>

            <ItemsControl ItemsSource="{Binding AiApps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:MacroAiAppItem">
                        <Border Classes="Card AiAppCard"
                                Classes.expanded="{Binding IsExpanded}"
                                Padding="14"
                                Margin="0,2,0,2">
                            <StackPanel Spacing="12">
                                <!-- System Prompt Header -->
                                <Button Classes="CardHeaderButton"
                                        BorderThickness="0"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Command="{Binding $parent[UserControl].((vm:MacroManagerViewModel)DataContext).ToggleExpandCommand}"
                                        CommandParameter="{Binding}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding SystemPrompt}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   MaxLines="3"/>
                                        <ic:SymbolIcon Grid.Column="1"
                                                       Symbol="ChevronDown"
                                                       VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <!-- Expanded Content -->
                                <StackPanel Spacing="10" IsVisible="{Binding IsExpanded}">

                                    <Border CornerRadius="8"
                                            Classes="ChatComposer"
                                            Padding="10"
                                            Background="{DynamicResource AppInputBackgroundBrush}"
                                            BorderBrush="{DynamicResource AppInputBorderBrush}"
                                            BorderThickness="1">
                                        <Grid RowDefinitions="*,Auto" RowSpacing="8" MinHeight="96">
                                            <TextBox Grid.Row="0"
                                                     Classes="ComposerInput"
                                                     Text="{Binding UserInput}"
                                                     PlaceholderText="Type user input..."
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     Padding="0"
                                                     MinHeight="54"
                                                     VerticalContentAlignment="Top"/>

                                            <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                                                <Button Grid.Column="0"
                                                        Classes="DeleteIconButton"
                                                        Width="30"
                                                        Height="30"
                                                        Padding="0"
                                                        Command="{Binding $parent[UserControl].((vm:MacroManagerViewModel)DataContext).DeleteAiAppCommand}"
                                                        CommandParameter="{Binding}"
                                                        VerticalAlignment="Center">
                                                    <ic:SymbolIcon Symbol="Delete" FontSize="14" Foreground="{DynamicResource AppDangerBrush}"/>
                                                </Button>

                                                <!-- Model display with brain icon (read-only) -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <ic:SymbolIcon Symbol="BrainCircuit" FontSize="14"/>
                                                    <TextBlock Text="{Binding SelectedModel}" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource AppAccentBrush}" FontWeight="SemiBold"/>
                                                </StackPanel>

                                                <!-- Spacer -->
                                                <Border Grid.Column="2"/>

                                                <!-- Attachment indicator shown only when an attachment exists -->
                                                <Button Grid.Column="3"
                                                        Classes="AttachIndicator"
                                                        Width="28"
                                                        Height="28"
                                                        MinWidth="28"
                                                        MinHeight="28"
                                                        MaxWidth="28"
                                                        MaxHeight="28"
                                                        Padding="0"
                                                        CornerRadius="14"
                                                        ToolTip.Tip="{Binding Attachment, Converter={StaticResource AttachmentTooltip}}"
                                                        IsVisible="{Binding Attachment, Converter={StaticResource NullToBool}}"
                                                        Command="{Binding $parent[UserControl].((vm:MacroManagerViewModel)DataContext).RemoveFileCommand}"
                                                        CommandParameter="{Binding}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center">
                                                    <ic:SymbolIcon Symbol="Attach" FontSize="12"/>
                                                </Button>

                                                <Button Grid.Column="4"
                                                        Classes="SendIconButton"
                                                        Width="30"
                                                        Height="30"
                                                        Padding="0"
                                                        CornerRadius="15"
                                                        ToolTip.Tip="Download AI response file"
                                                        Command="{Binding $parent[UserControl].((vm:MacroManagerViewModel)DataContext).DownloadResponseFileCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsVisible="{Binding ResponseFile, Converter={StaticResource NullToBool}}"
                                                        VerticalAlignment="Center">
                                                    <ic:SymbolIcon Symbol="CloudArrowDown" FontSize="14"/>
                                                </Button>

                                                <Button Grid.Column="5"
                                                        Classes="SendIconButton"
                                                        Width="30"
                                                        Height="30"
                                                        Padding="0"
                                                        CornerRadius="15"
                                                        Command="{Binding $parent[UserControl].((vm:MacroManagerViewModel)DataContext).SendCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding !IsBusy}"
                                                        VerticalAlignment="Center">
                                                    <Panel>
                                                        <ic:SymbolIcon Symbol="Send" FontSize="14" IsVisible="{Binding !IsBusy}"/>
                                                        <ic:SymbolIcon Symbol="Timer" FontSize="14" IsVisible="{Binding IsBusy}"/>
                                                    </Panel>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <TextBox Classes="AiAnswerBox"
                                             Text="{Binding AiAnswer}"
                                             IsReadOnly="True"
                                             IsVisible="{Binding AiAnswer, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                             TextWrapping="Wrap"
                                             Padding="10"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>

</UserControl>
