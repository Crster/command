<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ic="using:FluentIcons.Avalonia"
        xmlns:models="using:CrsterCommand.Models"
        xmlns:views="using:CrsterCommand.Windows"
        mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="600"
        x:Class="CrsterCommand.Windows.AddNoteDialog"
        x:DataType="views:AddNoteDialog"
        Title="{Binding HeaderText}"
        Width="800" Height="600"
        WindowStartupLocation="CenterOwner"
        CanMinimize="False"
        CanMaximize="False"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Window.Styles>
        <Style Selector="TabItem ic|SymbolIcon">
            <Setter Property="Foreground" Value="{DynamicResource AppSubtleTextBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TabItem:selected ic|SymbolIcon">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryAccentBrush}"/>
        </Style>
        <Style Selector="TabItem:pointerover ic|SymbolIcon">
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
        </Style>
        <Style Selector="Button.AiIconButton">
			<Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}"/>
        </Style>
        <Style Selector="Button.AiIconButton:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
        </Style>
        <Style Selector="Button.AiIconButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.AiIconButton:disabled /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Styles>

    <Panel>
        <!-- Background mimicking main window but darker -->
        <Panel IsHitTestVisible="False">
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="{DynamicResource AppBgStartColor}" Offset="0"/>
                        <GradientStop Color="{DynamicResource AppBgEndColor}"   Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <!-- Darkening overlay to make it a distinct dialog -->
            <Border Background="Black" Opacity="0.4"/>
        </Panel>

        <DockPanel Margin="24">
            <!-- Footer Actions -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,24,0,0">
                <Button Click="Cancel_Click" Classes="Secondary" Width="130" Height="42" HorizontalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ic:SymbolIcon Symbol="Dismiss" FontSize="18"/>
                        <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Click="Add_Click" Classes="Primary" Width="160" Height="42" HorizontalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ic:SymbolIcon Symbol="Save" FontSize="18"/>
                        <TextBlock Text="{Binding SaveButtonText}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Main Tabs -->
            <TabControl x:Name="TabControl" Theme="{StaticResource {x:Type TabControl}}" 
                        SelectionChanged="TabControl_SelectionChanged" 
                        Padding="0">
                <TabControl.ItemsPanel>
                    <ItemsPanelTemplate>
                            <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </TabControl.ItemsPanel>

                <!-- 1. Memory -->
                <TabItem IsEnabled="{Binding IsMemoryTabVisible}">
                    <TabItem.Header>
                        <StackPanel Spacing="6" HorizontalAlignment="Center" Margin="0,4"
                                    IsVisible="{Binding IsMemoryTabVisible}">
                            <ic:SymbolIcon Symbol="BrainCircuit" FontSize="20"/>
                            <TextBlock Text="Memory" FontSize="11" FontWeight="Medium"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid RowDefinitions="Auto,*,Auto" Margin="0,20,0,0">
                        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,12">
                            <TextBlock Text="Description" Classes="Label"/>
                            <TextBox x:Name="MemoryDescription" PlaceholderText="Short description (optional)">
                                <TextBox.InnerRightContent>
                                    <Button Classes="AiIconButton" Click="GenerateDescription_Click" Tag="Memory"
                                            IsEnabled="{Binding !IsGeneratingMemory}">
                                        <Panel>
                                            <ic:SymbolIcon Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Symbol="Sparkle" FontSize="14" IsVisible="{Binding !IsGeneratingMemory}"/>
                                            <ic:SymbolIcon Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Symbol="Timer" FontSize="14" IsVisible="{Binding IsGeneratingMemory}"/>
                                        </Panel>
                                    </Button>
                                </TextBox.InnerRightContent>
                            </TextBox>
                        </StackPanel>

                        <Border Grid.Row="1" Background="{DynamicResource AppInputBackgroundBrush}" 
                                CornerRadius="12" BorderThickness="1" 
                                BorderBrush="{DynamicResource AppInputBorderBrush}">
                            <Panel>
                                <TextBox x:Name="MemoryContent"
                                         PlaceholderText="Write something important to remember..."
                                         AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="16"
                                         FontFamily="Cascadia Code,Consolas,Menlo,Monaco,DejaVu Sans Mono,Courier New,monospace"
                                         FontSize="13"
                                         VerticalContentAlignment="Top"
                                         SelectionBrush="{DynamicResource AppAccentBrush}"
                                         KeyDown="MemoryContent_KeyDown"/>
                                <Border Background="#88000000" CornerRadius="12"
                                        IsVisible="{Binding IsOptimizing}"
                                        IsHitTestVisible="False">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                        <ic:SymbolIcon Symbol="Timer" FontSize="20" Foreground="White"/>
                                        <TextBlock Text="Optimizing..." Foreground="White" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </Panel>
                        </Border>

                        <!-- Find Bar -->
                        <Border Grid.Row="2"
                                IsVisible="{Binding IsSearchVisible}"
                                Background="{DynamicResource AppStatusBarBrush}"
                                BorderBrush="{DynamicResource AppInputBorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="8,6"
                                Margin="0,6,0,0">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="6">
                                <ic:SymbolIcon Grid.Column="0" Symbol="Search" FontSize="14"
                                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         x:Name="SearchBox"
                                         Text="{Binding SearchQuery}"
                                         PlaceholderText="Find... (F3 next, Shift+F3 prev, Esc close)"
                                         BorderThickness="0" Background="Transparent"
                                         Padding="4,0" Height="28"
                                         VerticalContentAlignment="Center"
                                         FontSize="13"
                                         TextChanged="SearchBox_TextChanged"
                                         KeyDown="SearchBox_KeyDown"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding SearchMatchInfo}"
                                           FontSize="12" VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           MinWidth="50"/>
                                <Button Grid.Column="3" Classes="AiIconButton"
                                        Width="26" Height="26" Padding="0"
                                        Click="SearchPrev_Click" ToolTip.Tip="Previous (Shift+F3)">
                                    <ic:SymbolIcon Symbol="ChevronUp" FontSize="13"/>
                                </Button>
                                <Button Grid.Column="4" Classes="AiIconButton"
                                        Width="26" Height="26" Padding="0"
                                        Click="SearchNext_Click" ToolTip.Tip="Next (F3)">
                                    <ic:SymbolIcon Symbol="ChevronDown" FontSize="13"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- 2. Todo -->
                <TabItem IsEnabled="{Binding IsTodoTabVisible}">
                    <TabItem.Header>
                        <StackPanel Spacing="6" HorizontalAlignment="Center" Margin="0,4"
                                    IsVisible="{Binding IsTodoTabVisible}">
                            <ic:SymbolIcon Symbol="List" FontSize="20"/>
                            <TextBlock Text="Todo" FontSize="11" FontWeight="Medium"/>
                        </StackPanel>
                    </TabItem.Header>

                    <Grid RowDefinitions="Auto,Auto,*" Margin="0,20,0,0">
                        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,12">
                            <TextBlock Text="Description" Classes="Label"/>
                            <TextBox x:Name="TodoDescription" PlaceholderText="Short description (optional)">
                                <TextBox.InnerRightContent>
                                    <Button Classes="AiIconButton" Click="GenerateDescription_Click" Tag="Todo"
                                            IsEnabled="{Binding !IsGeneratingTodo}">
                                        <Panel>
                                            <ic:SymbolIcon Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Symbol="Sparkle" FontSize="14" IsVisible="{Binding !IsGeneratingTodo}"/>
                                            <ic:SymbolIcon Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Symbol="Timer" FontSize="14" IsVisible="{Binding IsGeneratingTodo}"/>
                                        </Panel>
                                    </Button>
                                </TextBox.InnerRightContent>
                            </TextBox>
                        </StackPanel>

                        <!-- Fixed input for new todo -->
                        <TextBox Grid.Row="1" x:Name="NewTodoInput" 
                                 PlaceholderText="Add a task and press Enter..." 
                                 KeyDown="NewTodo_KeyDown"
                                 Margin="0,0,0,16">
                            <TextBox.InnerLeftContent>
                                <ic:SymbolIcon Symbol="Add" Margin="12,0,0,0" FontSize="16" Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                            </TextBox.InnerLeftContent>
                        </TextBox>

                        <!-- Scrollable list of existing todos -->
                        <ScrollViewer Grid.Row="2">
                            <ItemsControl ItemsSource="{Binding TodoList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:TodoSubTask">
                                        <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                                            <CheckBox IsChecked="{Binding IsDone}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Todo}" 
                                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                                       TextWrapping="Wrap" FontSize="14"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- 3. Vault -->
                <TabItem IsEnabled="{Binding IsVaultTabVisible}">
                    <TabItem.Header>
                        <StackPanel Spacing="6" HorizontalAlignment="Center" Margin="0,4"
                                    IsVisible="{Binding IsVaultTabVisible}">
                            <ic:SymbolIcon Symbol="LockClosed" FontSize="20"/>
                            <TextBlock Text="Vault" FontSize="11" FontWeight="Medium"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Panel Margin="0,20,0,0">
                        <!-- Setup View -->
                        <StackPanel Spacing="20" IsVisible="{Binding !HasVaultPassword}">
                            <Border Background="{DynamicResource AppStatusBarBrush}" 
                                    CornerRadius="12" Padding="20" BorderThickness="1" 
                                    BorderBrush="{DynamicResource AppInputBorderBrush}">
                                <StackPanel Spacing="12">
                                    <ic:SymbolIcon Symbol="ShieldLock" FontSize="32" Foreground="{DynamicResource AppAccentBrush}" 
                                                   HorizontalAlignment="Center"/>
                                    <TextBlock Text="Vault Not Configured" FontSize="16" FontWeight="Bold" 
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="To use the encrypted vault, you must first set a master password." 
                                               FontSize="13" Foreground="{DynamicResource AppSecondaryTextBrush}" 
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="New Master Password" Classes="Label"/>
                                <TextBox x:Name="SetupVaultPassword" 
                                         PlaceholderText="Choose a strong password..." 
                                         PasswordChar="●"/>
                            </StackPanel>
                            
                            <Button Content="Set Master Password" 
                                    Click="SetPassword_Click" 
                                    Classes="Primary" 
                                    HorizontalAlignment="Stretch" 
                                    Height="40"/>
                        </StackPanel>

                        <!-- Capture View -->
                        <Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding HasVaultPassword}">
                            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,12">
                                <TextBlock Text="Description" Classes="Label"/>
                                <TextBox x:Name="VaultDescription" 
                                         PlaceholderText="Short description (optional)">
                                    <TextBox.InnerRightContent>
                                        <Button Classes="AiIconButton" Click="GenerateDescription_Click" Tag="Vault"
                                                IsEnabled="{Binding !IsGeneratingVault}">
                                            <Panel>
                                                <ic:SymbolIcon Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Symbol="Sparkle" FontSize="14" IsVisible="{Binding !IsGeneratingVault}"/>
                                                <ic:SymbolIcon Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Symbol="Timer" FontSize="14" IsVisible="{Binding IsGeneratingVault}"/>
                                            </Panel>
                                        </Button>
                                    </TextBox.InnerRightContent>
                                </TextBox>
                            </StackPanel>

                            <Border Grid.Row="1" Background="{DynamicResource AppInputBackgroundBrush}" 
                                    CornerRadius="12" BorderThickness="1" 
                                    BorderBrush="{DynamicResource AppInputBorderBrush}"
                                    Margin="0,0,0,16">
                                <TextBox x:Name="VaultContent" 
                                         PlaceholderText="Enter sensitive information to encrypt..." 
                                         AcceptsReturn="True" 
                                         TextWrapping="Wrap"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="16"
                                         FontFamily="Cascadia Code,Consolas,Menlo,Monaco,DejaVu Sans Mono,Courier New,monospace"
                                         VerticalContentAlignment="Top"/>
                            </Border>

                            <Border Grid.Row="2" Background="{DynamicResource AppStatusBarBrush}" 
                                    CornerRadius="8" Padding="12" BorderThickness="1" 
                                    BorderBrush="{DynamicResource AppInputBorderBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ic:SymbolIcon Symbol="Info" FontSize="16" Foreground="{DynamicResource AppAccentBrush}"/>
                                    <TextBlock Text="Encrypted via Manual Master Password" 
                                               FontSize="11" VerticalAlignment="Center"
                                               Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Panel>
                </TabItem>

                <!-- 4. File -->
                <TabItem IsEnabled="{Binding IsFileTabVisible}">
                    <TabItem.Header>
                        <StackPanel Spacing="6" HorizontalAlignment="Center" Margin="0,4"
                                    IsVisible="{Binding IsFileTabVisible}">
                            <ic:SymbolIcon Symbol="Document" FontSize="20"/>
                            <TextBlock Text="File" FontSize="11" FontWeight="Medium"/>
                        </StackPanel>
                    </TabItem.Header>
                    <StackPanel Spacing="10" Margin="0,20,0,0">
                        <StackPanel Spacing="8" Margin="0,0,0,3">
                            <TextBlock Text="Description" Classes="Label"/>
                            <TextBox x:Name="FileDescription" PlaceholderText="Short description (optional)">
                                <TextBox.InnerRightContent>
                                    <Button Classes="AiIconButton" Click="GenerateDescription_Click" Tag="File"
                                            IsEnabled="{Binding !IsGeneratingFile}">
                                        <Panel>
                                            <ic:SymbolIcon Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Symbol="Sparkle" FontSize="14" IsVisible="{Binding !IsGeneratingFile}"/>
                                            <ic:SymbolIcon Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Symbol="Timer" FontSize="14" IsVisible="{Binding IsGeneratingFile}"/>
                                        </Panel>
                                    </Button>
                                </TextBox.InnerRightContent>
                            </TextBox>
                        </StackPanel>

                        <Button HorizontalAlignment="Stretch" Height="100" 
                                Click="SelectFile_Click" Classes="InputZone">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <ic:SymbolIcon Symbol="DocumentAdd" FontSize="32" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="SelectedFileName" Text="Click to select a file" 
                                           HorizontalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>

                        <!-- Existing File Actions -->
                        <StackPanel Spacing="12" IsVisible="{Binding IsEditMode}">
                            <TextBlock Text="File Actions" Classes="Label"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Button Grid.Column="0" Click="OpenFile_Click" HorizontalAlignment="Stretch" Padding="0,8">
                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                        <ic:SymbolIcon Symbol="Open" FontSize="20"/>
                                        <TextBlock Text="View" FontSize="11"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Click="SaveFileAs_Click" HorizontalAlignment="Stretch" Padding="0,8">
                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                        <ic:SymbolIcon Symbol="ArrowDownload" FontSize="20"/>
                                        <TextBlock Text="Save As" FontSize="11"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </DockPanel>

        <!-- Loading Overlay -->
        <Border Background="#AA000000" IsVisible="{Binding IsProcessing}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{DynamicResource AppAccentBrush}"/>
                <TextBlock Text="AI is generating description &amp; embeddings..." 
                           HorizontalAlignment="Center" 
                           Foreground="White" 
                           FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Panel>
</Window>
