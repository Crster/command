<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CrsterCommand.ViewModels"
        xmlns:ic="using:FluentIcons.Avalonia"
        x:Class="CrsterCommand.Windows.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Crster Command"
        Icon="/Assets/app.ico"
        Width="1040" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True">

    <Grid ColumnDefinitions="64,*">

        <!-- ══════════════════════════════════
             SIDEBAR
        ══════════════════════════════════ -->
        <Border Grid.Column="0" Background="{DynamicResource AppSidebarBrush}" Padding="0,32,0,0">
            <DockPanel>

                <!-- Brand icon -->
                <Border DockPanel.Dock="Top" Height="68"
                        HorizontalAlignment="Stretch">
                    <ic:SymbolIcon Symbol="Bot"
                                   FontSize="30"
                                   Foreground="{DynamicResource AppSidebarActiveIconBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                </Border>

                <!-- Navigation items (icon only) -->
                <ListBox Classes="NavList"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedListItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:NavigationItem">
                            <ic:SymbolIcon Symbol="{Binding Icon}"
                                           FontSize="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════
             CONTENT AREA  (gradient bg)
        ══════════════════════════════════ -->
        <Panel Grid.Column="1">

            <!-- Gradient background layer -->
            <Border IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="{DynamicResource AppBgStartColor}" Offset="0"/>
                        <GradientStop Color="{DynamicResource AppBgEndColor}"   Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Page content -->
            <TransitioningContentControl Content="{Binding CurrentPage}"/>

        </Panel>

    </Grid>
</Window>
