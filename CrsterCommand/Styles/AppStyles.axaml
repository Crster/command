<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ic="using:FluentIcons.Avalonia">

    <!-- ═══════════════════════════════════════
         BUTTON
    ═══════════════════════════════════════ -->
    <Style Selector="Button">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.05"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.Primary">
        <Setter Property="Background" Value="{DynamicResource AppAccentBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppAccentForegroundBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.Primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppAccentBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
    </Style>
    <Style Selector="Button.Primary:pointerover">
        <Setter Property="Opacity" Value="0.9"/>
    </Style>
    <Style Selector="Button.Primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppAccentBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
    </Style>
    <Style Selector="Button.Primary:pressed">
        <Setter Property="Opacity" Value="0.8"/>
        <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>
    <Style Selector="Button.Primary:disabled">
        <Setter Property="Opacity" Value="0.5"/>
        <Setter Property="Cursor" Value="No"/>
    </Style>

    <Style Selector="Button.Secondary">
        <Setter Property="Background" Value="{DynamicResource AppSecondaryAccentBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppAccentForegroundBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.Secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppSecondaryAccentBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppSecondaryAccentBrush}"/>
    </Style>
    <Style Selector="Button.Secondary:pointerover">
        <Setter Property="Opacity" Value="0.9"/>
    </Style>
    <Style Selector="Button.Secondary:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppSecondaryAccentBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppSecondaryAccentBrush}"/>
    </Style>
    <Style Selector="Button.Secondary:pressed">
        <Setter Property="Opacity" Value="0.8"/>
        <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>
    <Style Selector="Button.Secondary:disabled">
        <Setter Property="Opacity" Value="0.5"/>
        <Setter Property="Cursor" Value="No"/>
    </Style>

    <Style Selector="Button.InputZone">
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>
    <Style Selector="Button.InputZone:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
    </Style>
    <Style Selector="Button.InputZone:pressed">
        <Setter Property="RenderTransform" Value="scale(0.99)"/>
    </Style>
    <Style Selector="Button.InputZone:disabled">
        <Setter Property="Opacity" Value="0.5"/>
        <Setter Property="Cursor" Value="No"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderBrush}"/>
    </Style>
    <Style Selector="Button.InputZone ic|SymbolIcon">
        <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
    </Style>
    <Style Selector="Button.InputZone:disabled ic|SymbolIcon">
        <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}"/>
    </Style>

    <Style Selector="Button.Success">
        <Setter Property="Background" Value="{DynamicResource AppSuccessBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppSuccessForegroundBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.Success:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppSuccessBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppSuccessBrush}"/>
    </Style>
    <Style Selector="Button.Success:pointerover">
        <Setter Property="Opacity" Value="0.9"/>
    </Style>
    <Style Selector="Button.Success:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppSuccessBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppSuccessBrush}"/>
    </Style>
    <Style Selector="Button.Success:pressed">
        <Setter Property="Opacity" Value="0.8"/>
        <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>
    <Style Selector="Button.Success:disabled">
        <Setter Property="Opacity" Value="0.5"/>
        <Setter Property="Cursor" Value="No"/>
    </Style>

    <Style Selector="Button.Danger">
        <Setter Property="Background" Value="{DynamicResource AppDangerBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppDangerForegroundBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.Danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppDangerBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppDangerBrush}"/>
    </Style>
    <Style Selector="Button.Danger:pointerover">
        <Setter Property="Opacity" Value="0.9"/>
    </Style>
    <Style Selector="Button.Danger:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppDangerBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppDangerBrush}"/>
    </Style>
    <Style Selector="Button.Danger:pressed">
        <Setter Property="Opacity" Value="0.8"/>
        <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>
    <Style Selector="Button.Danger:disabled">
        <Setter Property="Opacity" Value="0.5"/>
        <Setter Property="Cursor" Value="No"/>
    </Style>

    <Style Selector="Button.CardHeaderButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
        <Setter Property="Padding" Value="0,8"/>
    </Style>
    <Style Selector="Button.CardHeaderButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Button.CardHeaderButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource AppSidebarHoverItemBrush}"/>
    </Style>
    <Style Selector="Button.CardHeaderButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Button.CardHeaderButton:pressed">
        <Setter Property="Background" Value="{DynamicResource AppSidebarActiveItemBrush}"/>
    </Style>
    <Style Selector="Button.CardHeaderButton:disabled">
        <Setter Property="Opacity" Value="0.5"/>
        <Setter Property="Cursor" Value="No"/>
    </Style>

    <!-- ═══════════════════════════════════════
         TEXTBOX
    ═══════════════════════════════════════ -->
    <Style Selector="TextBox">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- Remove the white border on hover and focus if desired, or make it subtle -->
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderBrush}"/>
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
    </Style>

    <!-- Consistent look on focus with a slight highlight -->
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════
         NUMERICUPDOWN
    ═══════════════════════════════════════ -->
    <Style Selector="NumericUpDown">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="NumericUpDown:error">
        <Setter Property="BorderBrush" Value="{DynamicResource AppDangerBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
    </Style>
    <Style Selector="NumericUpDown:invalid">
        <Setter Property="BorderBrush" Value="{DynamicResource AppDangerBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
    </Style>
    <Style Selector="NumericUpDown:focus:error">
        <Setter Property="BorderBrush" Value="{DynamicResource AppDangerBrush}"/>
    </Style>

    <Style Selector="NumericUpDown.NoSpinner">
        <Setter Property="ShowButtonSpinner" Value="False"/>
    </Style>

    <!-- ═══════════════════════════════════════
         COMBOBOX
    ═══════════════════════════════════════ -->
    <Style Selector="ComboBox">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ═══════════════════════════════════════
         PROGRESSBAR
    ═══════════════════════════════════════ -->
    <Style Selector="ProgressBar">
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="MinHeight" Value="8"/>
        <Setter Property="Background" Value="{DynamicResource AppInputBorderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════
         CARD BORDER
    ═══════════════════════════════════════ -->
    <Style Selector="Border.Card">
        <Setter Property="Background" Value="{DynamicResource AppCardBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="BoxShadow" Value="0 4 24 0 #28000020"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ═══════════════════════════════════════
         STATUS BAR BORDER
    ═══════════════════════════════════════ -->
    <Style Selector="Border.StatusBar">
        <Setter Property="Background" Value="{DynamicResource AppStatusBarBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ═══════════════════════════════════════
         SIDEBAR LISTBOX
    ═══════════════════════════════════════ -->
    <Style Selector="ListBox.NavList">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="8,0"/>
    </Style>
    <Style Selector="ListBox.NavList ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="MinHeight" Value="52"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="ListBox.NavList ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppSidebarActiveItemBrush}"/>
    </Style>
    <Style Selector="ListBox.NavList ListBoxItem:pointerover:not(:selected) /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppSidebarHoverItemBrush}"/>
    </Style>
    <Style Selector="ListBox.NavList ListBoxItem ic|SymbolIcon">
        <Setter Property="Foreground" Value="{DynamicResource AppSidebarIconBrush}"/>
    </Style>
    <Style Selector="ListBox.NavList ListBoxItem:selected ic|SymbolIcon">
        <Setter Property="Foreground" Value="{DynamicResource AppSidebarActiveIconBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════
         TYPOGRAPHY HELPERS
    ═══════════════════════════════════════ -->
    <Style Selector="TextBlock.PageTitle">
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
    </Style>
    <Style Selector="TextBlock.PageSubtitle">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}"/>
    </Style>
    <Style Selector="TextBlock.Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>
    <Style Selector="TextBlock.SectionHeader">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ═══════════════════════════════════════
         TABCONTROL
    ═══════════════════════════════════════ -->
    <Style Selector="TabItem">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,10"/>
    </Style>

</Styles>
